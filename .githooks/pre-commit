#!/bin/bash
# Pre-commit hook for ltmatrix
# Runs code quality checks before allowing commits
#
# This hook runs:
# - cargo fmt --check (formatting)
# - cargo clippy (linting)
# - cargo test (tests) - only for staged files

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Get the directory where the hook is located
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

cd "$PROJECT_ROOT"

# Track if any check fails
FAILED=0

# ====================
# Check 1: Formatting
# ====================
echo -e "${YELLOW}[1/3] Checking code formatting...${NC}"
if cargo fmt --check 2>/dev/null; then
    echo -e "${GREEN}✓ Code formatting is correct${NC}"
else
    echo -e "${RED}✗ Code formatting issues found${NC}"
    echo -e "${YELLOW}  Run 'cargo fmt' to fix${NC}"
    FAILED=1
fi

# ====================
# Check 2: Clippy
# ====================
echo -e "${YELLOW}[2/3] Running clippy...${NC}"
if cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo -e "${GREEN}✓ No clippy warnings${NC}"
else
    echo -e "${RED}✗ Clippy found issues${NC}"
    echo -e "${YELLOW}  Run 'cargo clippy --fix' for automatic fixes${NC}"
    FAILED=1
fi

# ====================
# Check 3: Tests (only if Rust files changed)
# ====================
# Check if any Rust files are staged
STAGED_RUST_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.rs$' || true)

if [ -n "$STAGED_RUST_FILES" ]; then
    echo -e "${YELLOW}[3/3] Running tests...${NC}"

    # Run only fast unit tests for pre-commit (skip slow integration tests)
    # Use --lib to only test the library crate (faster)
    if cargo test --lib -- --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ All tests passed${NC}"
    else
        echo -e "${RED}✗ Some tests failed${NC}"
        echo -e "${YELLOW}  Run 'cargo test' for details${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}[3/3] Skipping tests (no Rust files changed)${NC}"
fi

# ====================
# Summary
# ====================
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}✗ Pre-commit checks failed${NC}"
    echo -e "${YELLOW}Please fix the issues above before committing${NC}"
    echo ""
    echo "To bypass these checks temporarily, use:"
    echo "  git commit --no-verify"
    exit 1
fi
